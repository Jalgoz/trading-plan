{
    "_comment": "COPIA este archivo como config-live.json y agrega tus API keys. config-live.json está en .gitignore.",
    "trading_mode": "spot",
    "margin_mode": "",
    "max_open_trades": 2,
    "stake_currency": "USDT",
    "stake_amount": 20,
    "tradable_balance_ratio": 0.9,
    "fee": 0.001,
    "fiat_display_currency": "USD",
    "dry_run": false,
    "cancel_open_orders_on_exit": true,
    "unfilledtimeout": {
        "entry": 10,
        "exit": 10,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exchange": {
        "name": "binance",
        "key": "TU_API_KEY_AQUI",
        "secret": "TU_API_SECRET_AQUI",
        "ccxt_config": {},
        "ccxt_sync_config": {},
        "pair_whitelist": [
            "BTC/USDT",
            "ETH/USDT",
            "SOL/USDT"
        ],
        "pair_blacklist": []
    },
    "pairlists": [
        {
            "method": "StaticPairList"
        }
    ],
    "telegram": {
        "enabled": true,
        "token": "TU_TELEGRAM_BOT_TOKEN",
        "chat_id": "TU_CHAT_ID",
        "notification_settings": {
            "status": "silent",
            "warning": "on",
            "startup": "on",
            "entry": "on",
            "exit": "on"
        }
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret_key": "CAMBIA-ESTO-A-UN-STRING-ALEATORIO",
        "ws_token": "CAMBIA-ESTO-WS-TOKEN",
        "CORS_origins": [],
        "username": "freqtrade",
        "password": "CAMBIA-ESTE-PASSWORD"
    },
    "bot_name": "algo-bot-live",
    "initial_state": "stopped",
    "force_entry_enable": false,
    "internals": {
        "process_throttle_secs": 5
    },
    "freqai": {
        "enabled": true,
        "purge_old_models": 2,
        "train_period_days": 90,
        "backtest_period_days": 7,
        "live_retrain_hours": 168,
        "identifier": "lightgbm_live_v1",
        "feature_parameters": {
            "include_timeframes": [
                "1h",
                "4h"
            ],
            "include_corr_pairlist": [
                "BTC/USDT",
                "ETH/USDT"
            ],
            "indicator_periods_candles": [
                10,
                20,
                50
            ],
            "label_period_candles": 4,
            "include_shifted_candles": 2,
            "DI_threshold": 0.9,
            "weight_factor": 0.9,
            "principal_component_analysis": false,
            "use_SVM_to_remove_outliers": true,
            "svm_params": {
                "shuffle": false,
                "nu": 0.01
            }
        },
        "data_split_parameters": {
            "test_size": 0.33,
            "random_state": 1,
            "shuffle": false
        },
        "model_training_parameters": {
            "n_estimators": 400,
            "max_depth": 6,
            "learning_rate": 0.02,
            "num_leaves": 31,
            "min_child_samples": 20
        }
    },
    "dataformat_ohlcv": "feather",
    "dataformat_trades": "feather"
}
